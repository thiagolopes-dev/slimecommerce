generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  datacriacao DateTime @default(now())
  senha       String
  status      Boolean
}

model Cliente {
  id          Int      @id @default(autoincrement())
  cnpj        String   @unique
  razasocial  String
  fantasia    String
  logradouro  String
  numero      String
  bairro      String
  cidade      String
  uf          String
  status      Boolean
}

model Produto {
  id          Int      @id @default(autoincrement())
  descricao   String
  quantidade  Int
  sku         String   @unique
  status      Boolean
}

model PDV {
  id          Int      @id @default(autoincrement())
  produto     Produto  @relation(fields: [produtoId], references: [id])
  produtoId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  clienteId   Int
  data        DateTime @default(now())
  valor       Float
  pagamento   String
}